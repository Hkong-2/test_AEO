# Jarvis AEO Environment Configuration
# Copy this file to .env.dev, .env.staging, or .env.prod

# API Configuration
API_BASE_URL=http://jsonplaceholder.typicode.com
AI_API_BASE_URL=http://localhost:8080

# Google OAuth for login-google endpoint
GOOGLE_SERVER_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Analytics
ANALYTICS_ENABLED=false

# Error Tracking (Sentry)
SENTRY_DSN=

# Environment: dev, staging, prod
ENVIRONMENT=dev
