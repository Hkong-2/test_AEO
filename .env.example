# Jarvis AEO Environment Configuration
# Copy this file to .env.dev, .env.staging, or .env.prod

# API Configuration
API_BASE_URL=http://jsonplaceholder.typicode.com
AI_API_BASE_URL=http://localhost:8080

# Google OAuth for login-google endpoint
# IMPORTANT: For Google Sign-In on mobile, create an iOS OAuth Client ID on Google Cloud Console.
# Use the "Client ID" for GOOGLE_SERVER_CLIENT_ID and append ":/oauth2redirect" to the "iOS URL Scheme" for GOOGLE_REDIRECT_URI.
GOOGLE_SERVER_CLIENT_ID=
GOOGLE_REDIRECT_URI=

# Analytics
ANALYTICS_ENABLED=false

# Error Tracking (Sentry)
SENTRY_DSN=

# Environment: dev, staging, prod
ENVIRONMENT=dev
